def supports_color() -> bool:
    return sys.stderr.isatty() and os.environ.get("TERM", "") != "dumb"


def color(text: str, code: str) -> str:
    if not supports_color():
        return text
    return f"\033[{code}m{text}\033[0m"


def spinner(stop_event: threading.Event, message: str, frames: list[str]) -> None:
    if not frames:
        frames = SPINNER_STYLES["line"]

    index = 0
    max_frame_width = max(len(frame) for frame in frames)
    while not stop_event.is_set():
        frame = frames[index % len(frames)]
        sys.stderr.write(f"\r{color(frame, '36')} {message}")
        sys.stderr.flush()
        time.sleep(0.1)
        index += 1

    sys.stderr.write("\r" + " " * (len(message) + max_frame_width + 3) + "\r")
    sys.stderr.flush()


def normalize_prompt_text(prompt_parts: list[str], stdin_text: str) -> str:
    prompt = " ".join(prompt_parts).strip()
    stdin_text = stdin_text.strip()

    if stdin_text and prompt:
        return (
            "Use the following stdin content as additional context.\n\n"
            f"{stdin_text}\n\n"
            "User request:\n"
            f"{prompt}"
        )

    if stdin_text:
        return (
            "Use the following stdin content as context. "
            "If no explicit question is given, summarize the key points.\n\n"
            f"{stdin_text}"
        )

    return prompt


def extract_code_block(text: str) -> str:
    match = re.search(r"```(?:[\w.+-]+)?\n(.*?)```", text, re.DOTALL)
    if match:
        return match.group(1).strip()
    return text.strip()


def clean_command_output(text: str) -> str:
    cleaned = extract_code_block(text).strip().strip("`")

    def has_invalid_statement_syntax(line: str) -> bool:
        # Model prose often includes these, while shell commands usually should not.
        return "?" in line or "!" in line

    def shell_syntax_is_valid(line: str) -> bool:
        try:
            tokens = shlex.split(line, posix=True)
        except ValueError:
            return False
        if not tokens:
            return False
        first = tokens[0]
        return bool(re.match(r"^[A-Za-z0-9._/+~-]", first))

    lines: list[str] = []
    for raw_line in cleaned.splitlines():
        line = raw_line.strip()
        if not line:
            continue

        line = re.sub(r"^\$\s*", "", line)
        line = re.sub(r"^(?:- |\* |\d+\.\s+)", "", line)
        line = re.sub(r"^command\s*:\s*", "", line, flags=re.IGNORECASE)
        line = line.strip("` ")

        if line and not has_invalid_statement_syntax(line):
            lines.append(line)

    for candidate in lines:
        if shell_syntax_is_valid(candidate):
            return candidate.strip()

    if lines:
        sanitized = re.sub(r"[?!]+", "", lines[0]).strip()
        if shell_syntax_is_valid(sanitized):
            return sanitized

    if not lines:
        return ""

    return re.sub(r"[?!]+", "", lines[0]).strip()


