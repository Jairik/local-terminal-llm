def resolve_mode(
    prompt: str,
    args: argparse.Namespace,
    docs_root: Path,
) -> tuple[str, str]:
    if args.web:
        return "web", ""

    if args.docs and not args.auto:
        return "docs", args.docs

    if args.auto:
        if looks_freshness_sensitive(prompt):
            return "web", ""

        collection = args.docs or DEFAULT_DOCS_COLLECTION or find_first_collection(docs_root)
        if collection:
            return "docs", collection

        return "none", ""

    return "none", ""


def run_llm(
    prompt: str,
    model: str,
    system_prompt: str,
    show_spinner: bool,
    spinner_style: str,
) -> tuple[int, str, str]:
    if not shutil.which("llm"):
        return 127, "", "Error: `llm` is not installed or not on PATH."

    cmd = ["llm", "-m", model, "--no-stream"]
    if system_prompt:
        cmd.extend(["--system", system_prompt])
    cmd.append(prompt)

    stop_event = threading.Event()
    spinner_thread: threading.Thread | None = None
    spinner_frames = SPINNER_STYLES.get(spinner_style, SPINNER_STYLES["line"])

    try:
        if show_spinner and sys.stderr.isatty():
            spinner_thread = threading.Thread(
                target=spinner,
                args=(stop_event, f"Thinking with {model}", spinner_frames),
                daemon=True,
            )
            spinner_thread.start()

        proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    finally:
        stop_event.set()
        if spinner_thread is not None:
            spinner_thread.join()

    return proc.returncode, proc.stdout, proc.stderr


def run_llm_stream(
    prompt: str,
    model: str,
    system_prompt: str,
    show_spinner: bool,
    spinner_style: str,
    emit_stdout: bool,
    enable_stream_tts: bool,
) -> tuple[int, str, str]:
    if not shutil.which("llm"):
        return 127, "", "Error: `llm` is not installed or not on PATH."

    cmd = ["llm", "-m", model]
    if system_prompt:
        cmd.extend(["--system", system_prompt])
    cmd.append(prompt)

    stop_event = threading.Event()
    spinner_thread: threading.Thread | None = None
    spinner_frames = SPINNER_STYLES.get(spinner_style, SPINNER_STYLES["line"])

    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        bufsize=1,
    )

    tts_queue: queue.Queue[str | None] | None = None
    tts_thread: threading.Thread | None = None
    tts_stop_event: threading.Event | None = None
    if enable_stream_tts:
        model_path = Path(DEFAULT_TTS_MODEL).expanduser()
        if not shutil.which("piper"):
            log_info("[ask] TTS skipped: `piper` is not available on PATH.")
            enable_stream_tts = False
        elif not shutil.which("aplay"):
            log_info("[ask] TTS skipped: `aplay` is not available on PATH.")
            enable_stream_tts = False
        elif not model_path.is_file():
            log_info(
                f"[ask] TTS skipped: model not found at {model_path}. "
                "Set ASK_TTS_MODEL to a valid Piper model path."
            )
            enable_stream_tts = False

    if enable_stream_tts:
        tts_queue = queue.Queue(maxsize=4096)
        tts_stop_event = threading.Event()

        def _queue_iterator() -> Iterable[str]:
            pending = ""
            while True:
                if tts_stop_event is not None and tts_stop_event.is_set():
                    break
                try:
                    item = tts_queue.get(timeout=DEFAULT_TTS_DELAY_SECONDS)
                except queue.Empty:
                    if pending:
                        yield pending
                        pending = ""
                    continue
                if item is None:
                    break
                pending += item
                if any(mark in item for mark in ".!?\n") and len(pending) >= 24:
                    yield pending
                    pending = ""
                    continue
                if len(pending) >= 240:
                    yield pending
                    pending = ""
            if pending:
                yield pending

        tts_thread = threading.Thread(
            target=stream_tts,
            args=(_queue_iterator(), tts_stop_event),
            daemon=True,
        )
        tts_thread.start()

    output_parts: list[str] = []

    try:
        if show_spinner and sys.stderr.isatty():
            spinner_thread = threading.Thread(
                target=spinner,
                args=(stop_event, f"Thinking with {model}", spinner_frames),
                daemon=True,
            )
            spinner_thread.start()

        if proc.stdout is not None:
            while True:
                chunk = proc.stdout.read(1)
                if chunk == "":
                    break
                output_parts.append(chunk)
                if emit_stdout:
                    sys.stdout.write(chunk)
                    sys.stdout.flush()
                if tts_queue is not None:
                    if tts_thread is not None and not tts_thread.is_alive():
                        tts_queue = None
                    else:
                        try:
                            tts_queue.put_nowait(chunk)
                        except queue.Full:
                            pass
    except KeyboardInterrupt:
        if tts_stop_event is not None:
            tts_stop_event.set()
        _stop_process(proc, immediate=True)
        raise
    finally:
        stop_event.set()
        if spinner_thread is not None:
            spinner_thread.join()
        if tts_stop_event is not None:
            tts_stop_event.set()
        if tts_queue is not None:
            try:
                tts_queue.put_nowait(None)
            except queue.Full:
                try:
                    tts_queue.get_nowait()
                    tts_queue.put_nowait(None)
                except (queue.Empty, queue.Full):
                    pass
        if tts_thread is not None:
            tts_thread.join(timeout=5)

    stderr_text = ""
    if proc.stderr is not None:
        stderr_text = proc.stderr.read()
    return_code = proc.wait()
    output_text = "".join(output_parts)

    if emit_stdout and output_text and not output_text.endswith("\n"):
        sys.stdout.write("\n")
        sys.stdout.flush()

    return return_code, output_text, stderr_text


def main() -> int:
    args = parse_args()

    model = args.model.strip() or resolve_default_model()
    spinner_style = args.spinner_style.strip().lower() or resolve_spinner_style()
    did_configuration = False

    interactive_model_select = args.model_select == MODEL_SELECT_INTERACTIVE_SENTINEL

    if interactive_model_select:
        selected_model, _ = interactive_model_selection()
        ok, error = persist_default_model(selected_model)
        if not ok:
            sys.stderr.write(f"Error: could not persist selected model ({error}).\n")
            return 2
        log_info(f"[ask] Default model set to '{selected_model}'.")
        model = selected_model
        did_configuration = True

        if is_openai_model_name(selected_model) and prompt_yes_no(
            "Also save this as your power model?", default_yes=False
        ):
            ok, error = persist_power_model(selected_model)
            if not ok:
                sys.stderr.write(f"Error: could not persist power model ({error}).\n")
                return 2
            log_info(f"[ask] Power model set to '{selected_model}'.")
        elif not is_openai_model_name(selected_model):
            log_info("[ask] Selected model is non-OpenAI; it was not set as power model.")

    if args.model_select and args.model_select != MODEL_SELECT_INTERACTIVE_SENTINEL:
        selected_model = args.model_select.strip()
        if not selected_model:
            sys.stderr.write("Error: --model-select requires a non-empty model name.\n")
            return 2

        ok, error = persist_default_model(selected_model)
        if not ok:
            sys.stderr.write(f"Error: could not persist model selection ({error}).\n")
            return 2

        log_info(f"[ask] Default model set to '{selected_model}'.")
        if not args.model.strip():
            model = selected_model
        did_configuration = True

    if args.power_config:
        configured_power_model = args.power_config.strip()
        ok, error = persist_power_model(configured_power_model)
        if not ok:
            sys.stderr.write(f"Error: could not persist power model ({error}).\n")
            return 2
        log_info(f"[ask] Power model set to '{configured_power_model}'.")
        did_configuration = True

    if args.spinner_style_select:
        selected_spinner_style = args.spinner_style_select.strip().lower()
        ok, error = persist_spinner_style(selected_spinner_style)
        if not ok:
            sys.stderr.write(f"Error: could not persist spinner style ({error}).\n")
            return 2
        spinner_style = selected_spinner_style
        log_info(f"[ask] Spinner style set to '{selected_spinner_style}'.")
        did_configuration = True

    if args.env_setup:
        run_env_setup(shell_hint=args.env_shell, config_override=args.env_config_file)
        did_configuration = True

    if args.power:
        model = resolve_power_model()
        if not is_openai_model_name(model):
            sys.stderr.write(
                "Error: configured power model is not OpenAI-based. "
                "Use --power-config with an OpenAI model (for example: gpt-5.4).\n"
            )
            return 2
        log_info(f"[ask] Using power model '{model}'.")

    if did_configuration and not args.prompt:
        return 0

    stdin_text = sys.stdin.read() if not sys.stdin.isatty() else ""
    base_prompt = normalize_prompt_text(args.prompt, stdin_text)

    if not base_prompt.strip():
        sys.stderr.write("Usage: ask [options] \"your prompt here\"\n")
        return 2

    docs_root = Path(args.docs_db).expanduser()
    mode, docs_collection = resolve_mode(base_prompt, args, docs_root)

    final_prompt = base_prompt

    if mode == "web":
        log_info("[ask] Retrieving web context...")
        results, provider, error = search_web(base_prompt, args.web_provider)
        if error:
            if maybe_setup_missing_api_key(error):
                log_info("[ask] Retrying web retrieval after key setup...")
                results, provider, error = search_web(base_prompt, args.web_provider)
            if error:
                sys.stderr.write(f"Error: web augmentation unavailable ({error}).\n")
                return 3

        context_text = format_web_context(results)
        final_prompt = build_grounded_prompt(base_prompt, context_text, "web")
        log_info(f"[ask] Web grounding enabled via {provider} ({len(results)} results).")

    elif mode == "docs":
        if not docs_collection:
            sys.stderr.write("Error: docs mode requires a collection name.\n")
            return 2

        log_info(f"[ask] Retrieving docs context from collection '{docs_collection}'...")
        chunks, error = search_docs_collection(
            collection=docs_collection,
            docs_root=docs_root,
            query=base_prompt,
            limit=MAX_DOC_RESULTS,
        )
        if error:
            sys.stderr.write(f"Error: docs augmentation unavailable ({error}).\n")
            return 4

        context_text = format_docs_context(chunks, docs_collection)
        final_prompt = build_grounded_prompt(base_prompt, context_text, "docs")
        log_info(f"[ask] Docs grounding enabled ({len(chunks)} chunks).")

    elif args.auto:
        log_info("[ask] Auto mode found no available retrieval backend; running ungrounded.")

    if args.command_only:
        system_prompt = COMMAND_ONLY_SYSTEM
        if args.system:
            system_prompt = f"{system_prompt}\nAdditional constraints:\n{args.system.strip()}"
    else:
        system_prompt = args.system

    use_stream_tts = args.tts and args.tts_configure == "stream"
    output_was_stream_printed = False
    return_code = 1
    stdout_text = ""
    stderr_text = ""
    for attempt in range(2):
        if use_stream_tts:
            emit_stream_stdout = not args.command_only
            return_code, stdout_text, stderr_text = run_llm_stream(
                prompt=final_prompt,
                model=model,
                system_prompt=system_prompt,
                show_spinner=not args.no_spinner,
                spinner_style=spinner_style,
                emit_stdout=emit_stream_stdout,
                enable_stream_tts=True,
            )
            output_was_stream_printed = emit_stream_stdout
        else:
            return_code, stdout_text, stderr_text = run_llm(
                prompt=final_prompt,
                model=model,
                system_prompt=system_prompt,
                show_spinner=not args.no_spinner,
                spinner_style=spinner_style,
            )
        if return_code == 0:
            break
        if attempt == 0 and maybe_setup_missing_model(stderr_text, model_hint=model):
            log_info("[ask] Retrying model invocation after model setup...")
            continue
        if attempt == 0 and maybe_setup_missing_api_key(stderr_text, model_hint=model):
            log_info("[ask] Retrying model invocation after key setup...")
            continue
        break

    if return_code != 0:
        sys.stderr.write(stderr_text.strip() + "\n" if stderr_text.strip() else "Unknown llm error\n")
        return return_code

    output = stdout_text.strip()
    if args.command_only:
        output = clean_command_output(output)
        if args.no_output:
            if not output:
                sys.stderr.write("Error: no command was generated to execute.\n")
                return 1
            if args.tts and args.tts_configure != "stream":
                speak(output)
            return execute_generated_command(output)

    if output:
        if not output_was_stream_printed:
            sys.stdout.write(output)
            if not output.endswith("\n"):
                sys.stdout.write("\n")

        if args.tts and args.tts_configure != "stream":
            speak(output)

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        sys.stderr.write("\n")
        raise SystemExit(130)
    except RuntimeError as exc:
        sys.stderr.write(f"Error: {exc}\n")
        raise SystemExit(1)
