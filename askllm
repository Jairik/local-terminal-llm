def run_subprocess(cmd: list[str]) -> tuple[int, str, str]:
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    return proc.returncode, proc.stdout, proc.stderr


def _stop_process(proc: subprocess.Popen[bytes] | subprocess.Popen[str] | None, immediate: bool = False) -> None:
    if proc is None or proc.poll() is not None:
        return
    try:
        if immediate:
            proc.kill()
        else:
            proc.terminate()
    except OSError:
        return
    try:
        proc.wait(timeout=0.3 if immediate else 1.0)
    except subprocess.TimeoutExpired:
        try:
            proc.kill()
        except OSError:
            pass
        try:
            proc.wait(timeout=0.3)
        except subprocess.TimeoutExpired:
            pass


def speak(text: str) -> bool:
    phrase = text.strip()
    if not phrase:
        return False

    if not shutil.which("piper"):
        log_info("[ask] TTS skipped: `piper` is not available on PATH.")
        return False
    if not shutil.which("aplay"):
        log_info("[ask] TTS skipped: `aplay` is not available on PATH.")
        return False

    model_path = Path(DEFAULT_TTS_MODEL).expanduser()
    if not model_path.is_file():
        log_info(
            f"[ask] TTS skipped: model not found at {model_path}. "
            "Set ASK_TTS_MODEL to a valid Piper model path."
        )
        return False

    with AUDIO_PLAYBACK_LOCK:
        try:
            piper_proc = subprocess.Popen(
                ["piper", "--model", str(model_path), "--output-raw"],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            aplay_proc = subprocess.Popen(
                ["aplay", "-r", DEFAULT_TTS_SAMPLE_RATE, "-f", "S16_LE", "-t", "raw", "-"],
                stdin=piper_proc.stdout,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
            )

            if piper_proc.stdout is not None:
                piper_proc.stdout.close()

            if piper_proc.stdin is None:
                log_info("[ask] TTS skipped: Piper stdin unavailable.")
                return False
            piper_proc.stdin.write((phrase + "\n").encode("utf-8"))
            piper_proc.stdin.flush()
            piper_proc.stdin.close()

            piper_stderr = b""
            if piper_proc.stderr is not None:
                piper_stderr = piper_proc.stderr.read()
            aplay_stderr = b""
            if aplay_proc.stderr is not None:
                aplay_stderr = aplay_proc.stderr.read()

            piper_code = piper_proc.wait()
            aplay_code = aplay_proc.wait()

            if piper_code != 0:
                detail = piper_stderr.decode("utf-8", errors="replace").strip()
                log_info(f"[ask] TTS skipped: piper failed ({detail or 'exit code ' + str(piper_code)}).")
                return False
            if aplay_code != 0:
                detail = aplay_stderr.decode("utf-8", errors="replace").strip()
                log_info(f"[ask] TTS skipped: aplay failed ({detail or 'exit code ' + str(aplay_code)}).")
                return False

            return True
        except OSError as exc:
            log_info(f"[ask] TTS skipped: {exc}")
            return False


def _iter_tts_flush_chunks(text_iterator: Iterable[str]) -> Iterable[str]:
    buffer = ""
    carry = ""
    min_flush = 120
    max_flush = 260
    min_chunk = 48

    for piece in text_iterator:
        if not piece:
            continue
        buffer += piece

        while True:
            flush_at = -1
            terminal_match = None
            for match in re.finditer(r"[.!?](?:\s|$)|\n", buffer):
                terminal_match = match
            if terminal_match and terminal_match.end() >= min_flush:
                flush_at = terminal_match.end()
            elif len(buffer) >= max_flush:
                split_at = buffer.rfind(" ", 0, max_flush + 1)
                if split_at <= 0:
                    split_at = max_flush
                flush_at = split_at

            if flush_at <= 0:
                break

            chunk = buffer[:flush_at].strip()
            buffer = buffer[flush_at:]
            if chunk:
                if carry:
                    chunk = f"{carry} {chunk}".strip()
                    carry = ""
                if len(chunk) < min_chunk:
                    carry = chunk
                    continue
                yield chunk

    tail = f"{carry} {buffer.strip()}".strip()
    if tail:
        yield tail


def stream_tts(text_iterator: Iterable[str], stop_event: threading.Event | None = None) -> bool:
    if not shutil.which("piper"):
        log_info("[ask] TTS skipped: `piper` is not available on PATH.")
        return False
    if not shutil.which("aplay"):
        log_info("[ask] TTS skipped: `aplay` is not available on PATH.")
        return False

    model_path = Path(DEFAULT_TTS_MODEL).expanduser()
    if not model_path.is_file():
        log_info(
            f"[ask] TTS skipped: model not found at {model_path}. "
            "Set ASK_TTS_MODEL to a valid Piper model path."
        )
        return False

    stop_signal = stop_event or threading.Event()
    piper_proc: subprocess.Popen[bytes] | None = None
    aplay_proc: subprocess.Popen[bytes] | None = None

    with AUDIO_PLAYBACK_LOCK:
        try:
            piper_proc = subprocess.Popen(
                ["piper", "--model", str(model_path), "--output-raw"],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            aplay_proc = subprocess.Popen(
                ["aplay", "-r", DEFAULT_TTS_SAMPLE_RATE, "-f", "S16_LE", "-t", "raw", "-"],
                stdin=piper_proc.stdout,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
            )

            if piper_proc.stdout is not None:
                piper_proc.stdout.close()
            if piper_proc.stdin is None:
                log_info("[ask] TTS skipped: Piper stdin unavailable.")
                _stop_process(aplay_proc, immediate=True)
                _stop_process(piper_proc, immediate=True)
                return False

            wrote_any = False
            for chunk in _iter_tts_flush_chunks(text_iterator):
                if stop_signal.is_set():
                    break
                payload = chunk.strip()
                if not payload:
                    continue
                try:
                    piper_proc.stdin.write((payload + "\n").encode("utf-8"))
                    piper_proc.stdin.flush()
                except (BrokenPipeError, OSError):
                    stop_signal.set()
                    break
                wrote_any = True

            if piper_proc.stdin is not None and not piper_proc.stdin.closed:
                try:
                    piper_proc.stdin.close()
                except OSError:
                    pass

            if stop_signal.is_set():
                _stop_process(aplay_proc, immediate=True)
                _stop_process(piper_proc, immediate=True)
                return wrote_any

            piper_stderr = b""
            if piper_proc.stderr is not None:
                piper_stderr = piper_proc.stderr.read()
            aplay_stderr = b""
            if aplay_proc.stderr is not None:
                aplay_stderr = aplay_proc.stderr.read()

            piper_code = piper_proc.wait()
            aplay_code = aplay_proc.wait()

            if not wrote_any:
                return False
            if piper_code != 0:
                detail = piper_stderr.decode("utf-8", errors="replace").strip()
                log_info(f"[ask] TTS skipped: piper failed ({detail or 'exit code ' + str(piper_code)}).")
                return False
            if aplay_code != 0:
                detail = aplay_stderr.decode("utf-8", errors="replace").strip()
                log_info(f"[ask] TTS skipped: aplay failed ({detail or 'exit code ' + str(aplay_code)}).")
                return False

            return True
        except OSError as exc:
            log_info(f"[ask] TTS skipped: {exc}")
            return False
        finally:
            if stop_signal.is_set():
                _stop_process(aplay_proc, immediate=True)
                _stop_process(piper_proc, immediate=True)


def is_openai_model_name(model: str) -> bool:
    lowered = model.strip().lower()
    if lowered.startswith(("gpt-", "chatgpt-", "o1", "o3", "o4")):
        return True
    return lowered in {"4o", "4o-mini", "4.1", "4.1-mini", "4.1-nano", "gpt4", "4", "4t"}


def infer_provider_from_model(model: str) -> str | None:
    lowered = model.strip().lower()
    if not lowered:
        return None
    if is_openai_model_name(lowered):
        return "openai"
    if lowered.startswith("claude"):
        return "anthropic"
    if lowered.startswith(("gemini", "models/gemini")):
        return "google"
    if lowered.startswith("mistral"):
        return "mistral"
    if lowered.startswith("groq"):
        return "groq"
    return None


def provider_to_env_var(provider: str) -> str:
    normalized = provider.strip().lower()
    mapping = {
        "openai": "OPENAI_API_KEY",
        "anthropic": "ANTHROPIC_API_KEY",
        "google": "GOOGLE_API_KEY",
        "gemini": "GOOGLE_API_KEY",
        "exa": "EXA_API_KEY",
        "mistral": "MISTRAL_API_KEY",
        "groq": "GROQ_API_KEY",
        "openrouter": "OPENROUTER_API_KEY",
        "cohere": "COHERE_API_KEY",
        "huggingface": "HUGGINGFACE_API_KEY",
        "hf": "HUGGINGFACE_API_KEY",
    }
    if normalized in mapping:
        return mapping[normalized]
    sanitized = re.sub(r"[^A-Za-z0-9]+", "_", normalized).upper().strip("_")
    return f"{sanitized}_API_KEY" if sanitized else "API_KEY"


def read_llm_api_key(provider: str) -> str:
    normalized = provider.strip().lower()
    if not normalized:
        return ""
    if not shutil.which("llm"):
        return ""

    return_code, stdout, _ = run_subprocess(["llm", "keys", "get", normalized])
    if return_code != 0:
        return ""
    return stdout.strip()


def resolve_provider_api_key(provider: str, env_var: str) -> tuple[str, str | None]:
    value = os.environ.get(env_var, "").strip()
    if value:
        return value, None

    llm_value = read_llm_api_key(provider)
    if llm_value:
        os.environ[env_var] = llm_value
        return llm_value, None

    return "", f"{env_var} is not set and llm key '{provider}' was not found"


def parse_missing_api_key_error(error_text: str) -> tuple[str | None, str | None]:
    text = (error_text or "").strip()
    if not text:
        return None, None

    provider_patterns = [
        r"No key found for ['\"]?([A-Za-z0-9_.-]+)['\"]?",
        r"No API key found for ['\"]?([A-Za-z0-9_.-]+)['\"]?",
        r"Missing API key for ['\"]?([A-Za-z0-9_.-]+)['\"]?",
        r"provider ['\"]?([A-Za-z0-9_.-]+)['\"]? requires an API key",
    ]
    for pattern in provider_patterns:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if match:
            provider = match.group(1).strip().lower()
            if provider:
                return provider, provider_to_env_var(provider)

    env_match = re.search(r"\b([A-Z][A-Z0-9_]*_API_KEY)\b", text)
    if env_match:
        env_var = env_match.group(1).strip().upper()
        provider = env_var.removesuffix("_API_KEY").lower()
        return provider, env_var

    if "api key" in text.lower() and "not set" in text.lower():
        return None, "API_KEY"

    return None, None


def maybe_setup_missing_api_key(error_text: str, model_hint: str = "") -> bool:
    provider, env_var = parse_missing_api_key_error(error_text)

    if not provider and not env_var:
        inferred = infer_provider_from_model(model_hint)
        if inferred:
            provider = inferred
            env_var = provider_to_env_var(inferred)
        else:
            return False

    if not sys.stdin.isatty():
        return False

    label = provider or env_var or "unknown"
    if not prompt_yes_no(f"API key appears missing ({label}). Set one now?", default_yes=False):
        return False

    key_value = getpass.getpass(f"Paste API key for {label} (blank to cancel): ").strip()
    if not key_value:
        log_info("[ask] Key setup cancelled (empty value).")
        return False

    if provider:
        if shutil.which("llm"):
            return_code, _, stderr = run_subprocess(["llm", "keys", "set", provider, "--value", key_value])
            if return_code == 0:
                log_info(f"[ask] Saved API key for '{provider}' in llm.")
            else:
                detail = stderr.strip() or "llm keys set returned a non-zero exit code"
                log_info(f"[ask] Could not save llm key for '{provider}': {detail}")
        else:
            log_info("[ask] `llm` is not installed; skipping llm key store update.")

    if env_var:
        os.environ[env_var] = key_value
        log_info(f"[ask] Exported {env_var} for this process.")
        if prompt_yes_no("Print shell export command so you can copy/paste it?", default_yes=True):
            log_info("Run this in your shell:")
            log_info(f"export {env_var}={shlex.quote(key_value)}")

    return True


def parse_unknown_model_error(error_text: str) -> str | None:
    text = (error_text or "").strip()
    if not text:
        return None

    match = re.search(r"Unknown model:\s*['\"]?([A-Za-z0-9_.:/-]+)['\"]?", text, flags=re.IGNORECASE)
    if not match:
        return None

    model_name = match.group(1).strip().strip("'\"")
    if not model_name:
        return None
    return model_name


def llm_plugin_is_installed(plugin_name: str) -> bool:
    if not shutil.which("llm"):
        return False

    return_code, stdout, _ = run_subprocess(["llm", "plugins"])
    if return_code != 0:
        return False

    normalized_target = plugin_name.strip().lower()
    for line in stdout.splitlines():
        if normalized_target in line.strip().lower():
            return True
    return False


def ensure_llm_ollama_provider() -> tuple[bool, str | None]:
    if not shutil.which("llm"):
        return False, "`llm` is not installed or not on PATH"

    if llm_plugin_is_installed("llm-ollama"):
        return True, None

    log_info("[ask] Configuring local model provider plugin (`llm-ollama`)...")
    return_code, stdout, stderr = run_subprocess(["llm", "install", "llm-ollama"])
    if return_code != 0:
        detail = stderr.strip() or stdout.strip() or "llm install llm-ollama returned a non-zero exit code"
        if "already installed" not in detail.lower():
            return False, detail
    return True, None


def install_ollama_model(model_name: str) -> tuple[bool, str | None]:
    if not shutil.which("ollama"):
        return False, "`ollama` is not installed or not on PATH"

    return_code, stdout, stderr = run_subprocess(["ollama", "pull", model_name])
    if return_code != 0:
        detail = stderr.strip() or stdout.strip() or f"ollama pull exited with code {return_code}"
        return False, detail
    return True, None


def maybe_setup_missing_model(error_text: str, model_hint: str = "") -> bool:
    parsed_model = parse_unknown_model_error(error_text)
    if parsed_model is None:
        return False

    model_name = parsed_model

    if ":" not in model_name:
        return False

    if not sys.stdin.isatty() or not sys.stdout.isatty():
        return False

    if not prompt_yes_no(f"Model '{model_name}' is not installed. Install it now?", default_yes=True):
        return False

    ok, detail = ensure_llm_ollama_provider()
    if not ok:
        log_info(f"[ask] Could not configure `llm-ollama`: {detail}")
        return False

    log_info(f"[ask] Pulling local model '{model_name}' via Ollama...")
    ok, detail = install_ollama_model(model_name)
    if not ok:
        log_info(f"[ask] Could not install model '{model_name}': {detail}")
        if "ollama" in (detail or "").lower():
            log_info("[ask] Install Ollama first: https://ollama.com/download")
        return False

    models, models_error = available_models()
    if models_error:
        log_info(f"[ask] Installed model '{model_name}'. Could not verify via `llm models`: {models_error}")
    elif model_name not in models:
        log_info(
            f"[ask] Installed model '{model_name}', but `llm models` does not list it yet. "
            "You may need to restart your shell session."
        )
    else:
        log_info(f"[ask] Model '{model_name}' is ready.")
    return True


def parse_model_id_from_line(line: str) -> str:
    match = re.match(r"^[^:]+:\s+([^\s(]+)", line.strip())
    if not match:
        return ""
    return match.group(1).strip()


def available_models() -> tuple[list[str], str | None]:
    if not shutil.which("llm"):
        return [], "`llm` is not installed or not on PATH"

    return_code, stdout, stderr = run_subprocess(["llm", "models"])
    if return_code != 0:
        detail = stderr.strip() or "llm models returned a non-zero exit code"
        return [], detail

    models: list[str] = []
    for line in stdout.splitlines():
        model_id = parse_model_id_from_line(line)
        if model_id and model_id not in models:
            models.append(model_id)

    if not models:
        return [], "No models were returned by `llm models`"
    return models, None


def prompt_yes_no(question: str, default_yes: bool = False) -> bool:
    suffix = " [Y/n]: " if default_yes else " [y/N]: "
    answer = input(question + suffix).strip().lower()
    if not answer:
        return default_yes
    return answer in {"y", "yes"}


def normalize_shell_name(shell_name: str) -> str:
    lowered = shell_name.strip().lower()
    if "zsh" in lowered:
        return "zsh"
    if "bash" in lowered:
        return "bash"
    if "fish" in lowered:
        return "fish"
    if "ksh" in lowered or "mksh" in lowered or "pdksh" in lowered:
        return "ksh"
    if "sh" in lowered or "dash" in lowered:
        return "sh"
    return "sh"


def default_shell_config_for(shell_name: str) -> str:
    mapping = {
        "zsh": "~/.zshrc",
        "bash": "~/.bashrc",
        "fish": "~/.config/fish/config.fish",
        "ksh": "~/.kshrc",
        "sh": "~/.profile",
    }
    return mapping.get(shell_name, "~/.profile")


def escape_single_quoted_value(value: str) -> str:
    return value.replace("'", "'\\''")


def render_shell_env_line(shell_name: str, key: str, value: str) -> str:
    clean_value = value.replace("\n", " ").replace("\r", " ")
    escaped = escape_single_quoted_value(clean_value)
    if shell_name == "fish":
        return f"set -gx {key} '{escaped}'"
    return f"export {key}='{escaped}'"


def remove_marked_block(content: str, start_marker: str, end_marker: str) -> str:
    cleaned_lines: list[str] = []
    skipping = False
    for line in content.splitlines():
        if line == start_marker:
            skipping = True
            continue
        if line == end_marker:
            skipping = False
            continue
        if not skipping:
            cleaned_lines.append(line)
    return "\n".join(cleaned_lines)


def persist_env_block(
    config_path: Path,
    shell_name: str,
    env_values: dict[str, str],
    ordered_keys: list[str],
) -> tuple[bool, str | None]:
    lines = [
        ENV_CONFIG_MARKER_START,
        "# Generated by `ask --env-setup`.",
    ]
    for key in ordered_keys:
        if key in env_values:
            lines.append(render_shell_env_line(shell_name, key, env_values[key]))
    lines.append(ENV_CONFIG_MARKER_END)
    block = "\n".join(lines) + "\n"

    existing = ""
    if config_path.exists():
        try:
            existing = config_path.read_text(encoding="utf-8")
        except OSError as exc:
            return False, str(exc)

    cleaned = remove_marked_block(existing, ENV_CONFIG_MARKER_START, ENV_CONFIG_MARKER_END).rstrip("\n")
    if cleaned:
        payload = f"{cleaned}\n\n{block}"
    else:
        payload = block

    try:
        config_path.parent.mkdir(parents=True, exist_ok=True)
        config_path.write_text(payload, encoding="utf-8")
    except OSError as exc:
        return False, str(exc)
    return True, None


