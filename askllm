def prompt_env_setup_value(env_var: str, description: str, default_value: str) -> str | None:
    print(f"- {env_var}: {description}")
    shown_default = default_value if default_value != "" else "<empty>"
    value = input(f"  value [{shown_default}] (! to skip): ")
    if value.strip() == "!":
        return None
    if value == "":
        return default_value
    return value


def run_env_setup(shell_hint: str, config_override: str) -> None:
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        raise RuntimeError("--env-setup requires an interactive terminal")

    detected_shell = shell_hint if shell_hint != "auto" else os.path.basename(os.environ.get("SHELL", "sh"))
    shell_name = normalize_shell_name(detected_shell)

    if config_override.strip():
        config_path = Path(config_override).expanduser()
    else:
        config_path = Path(default_shell_config_for(shell_name)).expanduser()

    log_info("[ask] Environment setup wizard.")
    log_info("[ask] Press Enter to keep defaults. Type ! to skip a key.")
    log_info(f"[ask] Shell export syntax: {shell_name}")
    log_info(f"[ask] Target config file: {config_path}")

    if not prompt_yes_no("Use this config file path?", default_yes=True):
        custom_path = input("Config file path (blank to keep current): ").strip()
        if custom_path:
            config_path = Path(custom_path).expanduser()
            log_info(f"[ask] Updated config target: {config_path}")

    defaults = default_env_setup_values()
    env_values: dict[str, str] = {}
    ordered_keys: list[str] = []

    for section_name, fields in ENV_SETUP_SECTIONS:
        print(f"\n[{section_name}]")
        for env_var, description in fields:
            ordered_keys.append(env_var)
            default_value = defaults.get(env_var, "")
            selected = prompt_env_setup_value(env_var, description, default_value)
            if selected is None:
                continue
            env_values[env_var] = selected

    print("\n[API Keys]")
    print("Values are hidden while typing. Blank input skips that provider.")
    provider_values: list[tuple[str, str, str]] = []
    for provider, env_var in API_KEY_SETUP_FIELDS:
        key_value = getpass.getpass(f"  {env_var} ({provider}): ").strip()
        if key_value:
            provider_values.append((provider, env_var, key_value))

    if provider_values:
        saved_count = 0
        if not shutil.which("llm"):
            log_info("[ask] `llm` not found; API keys were loaded only for this process.")
            for _, env_var, key_value in provider_values:
                os.environ[env_var] = key_value
        else:
            for provider, env_var, key_value in provider_values:
                return_code, _, stderr = run_subprocess(["llm", "keys", "set", provider, "--value", key_value])
                if return_code == 0:
                    saved_count += 1
                    os.environ[env_var] = key_value
                else:
                    detail = stderr.strip() or "llm keys set returned a non-zero exit code"
                    log_info(f"[ask] Could not store llm key '{provider}': {detail}")
            if saved_count:
                log_info(f"[ask] Stored {saved_count} API key(s) in local llm key store.")

        if prompt_yes_no(
            "Also write API keys into your shell config as env vars? (less secure)",
            default_yes=False,
        ):
            for _, env_var, key_value in provider_values:
                env_values[env_var] = key_value
                if env_var not in ordered_keys:
                    ordered_keys.append(env_var)
            log_info("[ask] API keys will also be written into the env config block.")

    if not env_values:
        log_info("[ask] No non-secret environment values selected for shell config update.")
        return

    if not prompt_yes_no(f"Write environment block to {config_path}?", default_yes=True):
        log_info("[ask] Skipped writing shell config block.")
        return

    ok, error = persist_env_block(config_path, shell_name, env_values, ordered_keys)
    if not ok:
        raise RuntimeError(f"Could not persist env configuration: {error}")

    log_info(f"[ask] Saved environment configuration block to {config_path}.")
    log_info("[ask] Reload your shell or source the config file to apply changes.")


def clip_text(text: str, max_length: int) -> str:
    if len(text) <= max_length:
        return text
    if max_length <= 3:
        return text[:max_length]
    return text[: max_length - 3] + "..."


def model_ascii_card(model: str, title: str) -> str:
    width = 68
    inner_width = width - 4
    family = "OpenAI" if is_openai_model_name(model) else "Local/Other"
    power_eligible = "yes" if is_openai_model_name(model) else "no"

    if is_openai_model_name(model):
        art = [
            "    ____   ____   _____   _   _    ___ ",
            "   / __ \\ / __ \\ |  __ \\ | \\ | |  / _ \\",
            "  | |  | | |  | || |__) ||  \\| | | | | |",
            "  | |  | | |  | ||  ___/ | . ` | | | | |",
            "  | |__| | |__| || |     | |\\  | | |_| |",
            "   \\____/ \\____/ |_|     |_| \\_|  \\___/ ",
        ]
    else:
        art = [
            "        _                    _ ",
            "       | |                  | |",
            "   ___ | |  ___    ___  __ _| |",
            "  / __|| | / _ \\  / __|/ _` | |",
            "  \\__ \\| || (_) || (__| (_| | |",
            "  |___/|_| \\___/  \\___|\\__,_|_|",
        ]

    def boxed_line(content: str = "") -> str:
        return f"| {clip_text(content, inner_width).ljust(inner_width)} |"

    lines = ["+" + "-" * (width - 2) + "+"]
    lines.append(boxed_line(title))
    lines.append(boxed_line(f"Model          : {model}"))
    lines.append(boxed_line(f"Family         : {family}"))
    lines.append(boxed_line(f"Power eligible : {power_eligible}"))
    lines.append(boxed_line())
    for line in art:
        lines.append(boxed_line(line))
    lines.append("+" + "-" * (width - 2) + "+")
    return "\n".join(lines)


def interactive_model_selection() -> tuple[str, bool]:
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        raise RuntimeError("--model-select/--select-model requires an interactive terminal")

    models, error = available_models()
    if error:
        raise RuntimeError(f"Could not read models from `llm`: {error}")

    current_default_model = resolve_default_model()
    print("\n" + model_ascii_card(current_default_model, "Current Selected Model"))

    filter_text = input("Model filter (blank for all): ").strip().lower()
    visible = [model for model in models if filter_text in model.lower()] if filter_text else models
    if not visible:
        raise RuntimeError("No models matched the selected filter")

    print("\nAvailable models:")
    for idx, model in enumerate(visible, start=1):
        print(f"{idx:3d}. {model}")

    selection_text = input("\nSelect model number: ").strip()
    if not selection_text.isdigit():
        raise RuntimeError("Model selection must be a numeric choice")

    selection_index = int(selection_text)
    if selection_index < 1 or selection_index > len(visible):
        raise RuntimeError("Selected model number is out of range")

    selected_model = visible[selection_index - 1]
    print("\n" + model_ascii_card(selected_model, "New Selected Model"))
    print(f"[ask] Selected model: {selected_model}")

    default_provider = infer_provider_from_model(selected_model) or "openai"
    provider = input(
        f"Provider key name for API key (blank to skip, default: {default_provider}): "
    ).strip()
    if not provider:
        provider = default_provider

    key_value = getpass.getpass(f"Paste API key for '{provider}' (blank to skip): ").strip()
    key_set = False
    if key_value:
        return_code, _, stderr = run_subprocess(["llm", "keys", "set", provider, "--value", key_value])
        if return_code != 0:
            detail = stderr.strip() or "llm keys set returned a non-zero exit code"
            raise RuntimeError(f"Could not save API key: {detail}")
        key_set = True
        print(f"[ask] Saved API key for '{provider}'.")

    return selected_model, key_set


def execute_generated_command(command: str) -> int:
    if not sys.stdin.isatty():
        sys.stderr.write("Error: --no-output requires interactive confirmation on a TTY.\n")
        return 2

    sys.stderr.write(
        "[ask] Confirmation required: this command will execute directly and may modify files.\n"
    )
    sys.stderr.write(f"[ask] Command: {command}\n")
    if not prompt_yes_no("Execute command now?", default_yes=False):
        sys.stderr.write("[ask] Command execution cancelled.\n")
        return 1

    shell = os.environ.get("SHELL", "/bin/zsh")
    proc = subprocess.run(
        command,
        shell=True,
        executable=shell,
        text=True,
        capture_output=True,
        check=False,
    )

    if proc.returncode == 0:
        sys.stderr.write("[ask] Command executed successfully.\n")
        return 0

    stderr = proc.stderr.strip()
    if stderr:
        sys.stderr.write(stderr + "\n")
    sys.stderr.write(f"[ask] Command failed with exit code {proc.returncode}.\n")
    return proc.returncode


def search_web_exa(query: str, max_results: int = MAX_WEB_RESULTS) -> tuple[list[SearchResult], str | None]:
    api_key, key_error = resolve_provider_api_key("exa", "EXA_API_KEY")
    if key_error:
        return [], key_error

    payload = {
        "query": query,
        "numResults": max_results,
        "type": "auto",
        "contents": {"text": {"maxCharacters": 800}},
    }

    request = urllib.request.Request(
        "https://api.exa.ai/search",
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Content-Type": "application/json",
            "x-api-key": api_key,
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=20) as response:
            body = response.read().decode("utf-8")
    except urllib.error.URLError as exc:
        return [], f"Exa request failed: {exc}"
    except TimeoutError:
        return [], "Exa request timed out"

    try:
        payload_obj = json.loads(body)
    except json.JSONDecodeError:
        return [], "Exa returned non-JSON output"

    results: list[SearchResult] = []
    for item in payload_obj.get("results", []):
        title = (item.get("title") or "Untitled").strip()
        url = (item.get("url") or "").strip()
        snippet = (item.get("text") or "").strip()
        if not snippet and item.get("highlights"):
            highlights = item.get("highlights")
            if isinstance(highlights, list):
                snippet = " ".join(str(part).strip() for part in highlights if str(part).strip())

        if url:
            results.append(SearchResult(title=title, url=url, snippet=snippet[:1200]))

    if not results:
        return [], "Exa returned no results"

    return results, None


def search_web_ddgr(query: str, max_results: int = MAX_WEB_RESULTS) -> tuple[list[SearchResult], str | None]:
    if not shutil.which("ddgr"):
        return [], "ddgr is not installed"

    return_code, stdout, stderr = run_subprocess(
        ["ddgr", "--json", "-n", str(max_results), query]
    )

    if return_code != 0:
        detail = stderr.strip() or "ddgr returned a non-zero exit code"
        return [], detail

    try:
        payload_obj = json.loads(stdout)
    except json.JSONDecodeError:
        return [], "ddgr returned non-JSON output"

    results: list[SearchResult] = []
    for item in payload_obj:
        title = str(item.get("title", "Untitled")).strip()
        url = str(item.get("url", "")).strip()
        snippet = str(item.get("abstract", "")).strip()
        if url:
            results.append(SearchResult(title=title, url=url, snippet=snippet[:1200]))

    if not results:
        return [], "ddgr returned no results"

    return results, None


def search_web(query: str, provider: str) -> tuple[list[SearchResult], str, str | None]:
    chosen = provider.lower()

    if chosen not in {"auto", "exa", "ddgr"}:
        return [], chosen, f"Unknown web provider: {provider}"

    errors: list[str] = []

    if chosen in {"auto", "exa"}:
        results, error = search_web_exa(query)
        if results:
            return results, "exa", None
        if error:
            errors.append(f"exa: {error}")
        if chosen == "exa":
            return [], "exa", "; ".join(errors)

    if chosen in {"auto", "ddgr"}:
        results, error = search_web_ddgr(query)
        if results:
            return results, "ddgr", None
        if error:
            errors.append(f"ddgr: {error}")
        if chosen == "ddgr":
            return [], "ddgr", "; ".join(errors)

    return [], "auto", "; ".join(errors) if errors else "No web provider available"


def format_web_context(results: list[SearchResult]) -> str:
    lines: list[str] = []
    for idx, result in enumerate(results, start=1):
        lines.append(f"[{idx}] {result.title}")
        lines.append(f"URL: {result.url}")
        if result.snippet:
            lines.append(f"Snippet: {result.snippet}")
        lines.append("")
    return "\n".join(lines).strip()


def discover_doc_files(collection_dir: Path) -> list[Path]:
    files: list[Path] = []
    for root, dirs, filenames in os.walk(collection_dir):
        dirs[:] = [name for name in dirs if name != ".index" and not name.startswith(".")]

        for filename in filenames:
            file_path = Path(root) / filename

            if filename.startswith("."):
                continue

            extension = file_path.suffix.lower()
            if extension in TEXT_EXTENSIONS or extension == "":
                files.append(file_path)

    files.sort()
    return files


def safe_read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return ""


def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> list[str]:
    cleaned = text.strip()
    if not cleaned:
        return []

    chunks: list[str] = []
    start = 0
    text_len = len(cleaned)

    while start < text_len:
        end = min(start + chunk_size, text_len)
        candidate = cleaned[start:end]

        if end < text_len:
            newline_cutoff = candidate.rfind("\n")
            if newline_cutoff > chunk_size // 2:
                end = start + newline_cutoff
                candidate = cleaned[start:end]

        chunk = candidate.strip()
        if chunk:
            chunks.append(chunk)

        if end >= text_len:
            break

        start = max(end - overlap, start + 1)

    return chunks


def collection_signature(files: list[Path], root: Path) -> str:
    hasher = hashlib.sha256()
    for path in files:
        try:
            stat = path.stat()
        except OSError:
            continue
        rel_path = str(path.relative_to(root))
        hasher.update(rel_path.encode("utf-8", errors="ignore"))
        hasher.update(str(stat.st_mtime_ns).encode("ascii", errors="ignore"))
        hasher.update(str(stat.st_size).encode("ascii", errors="ignore"))
    return hasher.hexdigest()


def open_docs_db(db_path: Path) -> sqlite3.Connection:
    db_path.parent.mkdir(parents=True, exist_ok=True)
    connection = sqlite3.connect(db_path)
    connection.execute("PRAGMA journal_mode=WAL")
    connection.execute("PRAGMA synchronous=NORMAL")
    return connection


def initialize_docs_db(connection: sqlite3.Connection) -> None:
    connection.execute(
        """
        CREATE TABLE IF NOT EXISTS docs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            source TEXT NOT NULL,
            chunk_no INTEGER NOT NULL,
            content TEXT NOT NULL
        )
        """
    )
    connection.execute(
        """
        CREATE TABLE IF NOT EXISTS meta (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        )
        """
    )
    connection.commit()


def get_meta(connection: sqlite3.Connection, key: str) -> str:
    row = connection.execute("SELECT value FROM meta WHERE key = ?", (key,)).fetchone()
    return row[0] if row else ""


def set_meta(connection: sqlite3.Connection, key: str, value: str) -> None:
    connection.execute(
        "INSERT INTO meta(key, value) VALUES(?, ?) "
        "ON CONFLICT(key) DO UPDATE SET value = excluded.value",
        (key, value),
    )


def rebuild_docs_index(
    connection: sqlite3.Connection,
    files: list[Path],
    collection_root: Path,
    signature: str,
) -> int:
    connection.execute("DELETE FROM docs")

    inserted = 0
    for file_path in files:
        text = safe_read_text(file_path)
        if not text.strip():
            continue

        relative_source = str(file_path.relative_to(collection_root))
        chunks = chunk_text(text)

        for chunk_no, chunk in enumerate(chunks):
            connection.execute(
                "INSERT INTO docs(source, chunk_no, content) VALUES(?, ?, ?)",
                (relative_source, chunk_no, chunk),
            )
            inserted += 1

    connection.execute("DROP TABLE IF EXISTS docs_fts")
    fts_enabled = "0"

    try:
        connection.execute(
            "CREATE VIRTUAL TABLE docs_fts USING fts5(content, source UNINDEXED, chunk_no UNINDEXED)"
        )
        connection.execute(
            "INSERT INTO docs_fts(rowid, content, source, chunk_no) "
            "SELECT id, content, source, chunk_no FROM docs"
        )
        fts_enabled = "1"
    except sqlite3.OperationalError:
        fts_enabled = "0"

    set_meta(connection, "signature", signature)
    set_meta(connection, "fts_enabled", fts_enabled)
    connection.commit()
    return inserted


def tokenize_query(text: str) -> list[str]:
    tokens = re.findall(r"[a-zA-Z0-9_:+.-]{2,}", text.lower())
    seen: set[str] = set()
    unique_tokens: list[str] = []
    for token in tokens:
        if token not in seen:
            unique_tokens.append(token)
            seen.add(token)
    return unique_tokens


def build_fts_query(query: str) -> str:
    tokens = tokenize_query(query)
    if not tokens:
        return query.strip()
    quoted = [f'"{token}"' for token in tokens[:12]]
    return " OR ".join(quoted)


def lexical_rank(rows: Iterable[tuple[str, int, str]], query: str, limit: int) -> list[DocChunk]:
    tokens = tokenize_query(query)
    if not tokens:
        return []

    ranked: list[DocChunk] = []
    for source, chunk_no, content in rows:
        lowered = content.lower()
        score = 0.0
        for token in tokens:
            if token in lowered:
                score += lowered.count(token)
        if score > 0:
            ranked.append(DocChunk(source=source, chunk_no=chunk_no, content=content, score=score))

    ranked.sort(key=lambda item: item.score, reverse=True)
    return ranked[:limit]


def search_docs_collection(
    collection: str,
    docs_root: Path,
    query: str,
    limit: int = MAX_DOC_RESULTS,
) -> tuple[list[DocChunk], str | None]:
    collection_dir = docs_root / collection
    if not collection_dir.exists() or not collection_dir.is_dir():
        return [], f"Docs collection '{collection}' not found at {collection_dir}"

    files = discover_doc_files(collection_dir)
    if not files:
        return [], f"Docs collection '{collection}' has no readable text files"

    signature = collection_signature(files, collection_dir)
    db_path = docs_root / ".index" / f"{collection}.sqlite3"

    connection = open_docs_db(db_path)
    try:
        initialize_docs_db(connection)
        stored_signature = get_meta(connection, "signature")
        docs_count_row = connection.execute("SELECT COUNT(*) FROM docs").fetchone()
        docs_count = int(docs_count_row[0]) if docs_count_row else 0

        if stored_signature != signature or docs_count == 0:
            indexed = rebuild_docs_index(connection, files, collection_dir, signature)
            if indexed == 0:
                return [], f"Docs collection '{collection}' produced no searchable chunks"

        fts_enabled = get_meta(connection, "fts_enabled") == "1"

        if fts_enabled:
            fts_query = build_fts_query(query)
            try:
                rows = connection.execute(
                    "SELECT source, chunk_no, content, bm25(docs_fts) AS score "
                    "FROM docs_fts WHERE docs_fts MATCH ? ORDER BY score LIMIT ?",
                    (fts_query, limit),
                ).fetchall()
            except sqlite3.OperationalError:
                rows = []

            chunks: list[DocChunk] = [
                DocChunk(source=row[0], chunk_no=int(row[1]), content=row[2], score=float(row[3]))
                for row in rows
            ]

            if chunks:
                return chunks, None

        plain_rows = connection.execute(
            "SELECT source, chunk_no, content FROM docs"
        ).fetchall()
        ranked = lexical_rank(plain_rows, query, limit)

        if ranked:
            return ranked, None

        return [], f"No relevant documentation chunks found in collection '{collection}'"

    finally:
        connection.close()


def format_docs_context(chunks: list[DocChunk], collection: str) -> str:
    lines: list[str] = [f"Collection: {collection}"]
    for idx, chunk in enumerate(chunks, start=1):
        lines.append(f"[{idx}] Source: {chunk.source} (chunk {chunk.chunk_no})")
        lines.append(chunk.content.strip())
        lines.append("")
    return "\n".join(lines).strip()


def find_first_collection(docs_root: Path) -> str:
    if not docs_root.exists() or not docs_root.is_dir():
        return ""

    entries = []
    for child in docs_root.iterdir():
        if child.is_dir() and child.name != ".index" and not child.name.startswith("."):
            entries.append(child.name)

    entries.sort()
    return entries[0] if entries else ""


def build_grounded_prompt(user_prompt: str, context_text: str, context_kind: str) -> str:
    context_label = "web search results" if context_kind == "web" else "local documentation"

    return (
        f"You must answer using only the provided {context_label}.\n"
        "If the answer is not supported by the context, reply exactly with: "
        "'I don't have enough grounded context to answer that.'\n"
        "Prefer exact option names, command flags, API names, and code snippets when present.\n\n"
        "Grounding context:\n"
        f"{context_text}\n\n"
        "User request:\n"
        f"{user_prompt.strip()}"
    )


